{
  "name": "portfolio",
  "version": "0.1.0",
  "description": "My website",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,json,scss,css,html,astro,yml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,scss,css,html,astro,yml}\"",
    "test:e2e": "playwright test"
  },
  "author": "josh.laidlaw@gmail.com",
  "license": "BSD-2-Clause",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.54.2",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "astro": "^7.0.3",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^2.1.0",
    "globals": "^17.7.0",
    "modern-normalize": "^3.0.1",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.44.1"
  },
  "dependencies": {
    "swiper": "^12.2.0"
  }
}
