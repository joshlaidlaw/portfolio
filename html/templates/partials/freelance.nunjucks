              <img srcset="img/freelance/nvbc/nvbc_annual_report.png, img/freelance/nvbc/nvbc_annual_report@2x.png 2x" alt="">
            </div>
            <div class="swiper-slide">
              <img srcset="img/freelance/nvbc/nvbc_postcard.png, img/freelance/nvbc/nvbc_postcard@2x.png 2x" alt="">
